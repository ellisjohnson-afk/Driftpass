{
  "name": "driftpass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --dir src",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "db:types": "supabase gen types typescript --linked > src/types/database.types.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:apply-005": "node scripts/apply-migration-005.mjs",
    "db:apply-006": "node scripts/apply-migration-006.mjs",
    "db:apply-007": "node scripts/apply-migration-007.mjs",
    "db:apply-008": "node scripts/apply-migration-008.mjs",
    "launch:check": "node scripts/e2e-checklist.mjs https://www.driftpass.com.au",
    "stripe:verify": "node scripts/verify-stripe-prices.mjs",
    "auth:link": "node scripts/generate-auth-link.mjs",
    "email:verify": "node scripts/verify-resend.mjs",
    "test:pin": "node scripts/test-pin-windows.mjs",
    "test:e2e": "node scripts/e2e-checklist.mjs",
    "test:collect-e2e": "node scripts/test-partner-collect-e2e.mjs https://www.driftpass.com.au",
    "vercel:env": "node scripts/sync-vercel-env.mjs",
    "vercel:env:dry": "node scripts/sync-vercel-env.mjs --dry-run"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^16.5.0",
    "qrcode": "^1.5.4",
    "resend": "^3.4.0",
    "zod": "^3.23.8",
    "framer-motion": "^11.3.28",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "date-fns": "^3.6.0",
    "html5-qrcode": "^2.3.8",
    "@upstash/ratelimit": "^2.0.3",
    "@upstash/redis": "^1.34.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.14",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.41",
    "supabase": "^1.187.10",
    "tailwindcss": "^3.4.9",
    "typescript": "^5.5.4"
  }
}
