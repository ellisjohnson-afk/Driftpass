# ============================================================
# DriftPass Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================================

# Supabase — get from supabase.com project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # server-only, never expose to client

# Stripe — get from stripe.com dashboard
STRIPE_SECRET_KEY=sk_live_...           # use sk_test_... for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...         # from stripe webhook endpoint settings

# Stripe Price IDs — fortnightly billing (interval=week, interval_count=2)
STRIPE_WANDERER_PRICE_ID=price_...      # A$20 / 2 weeks — Wanderer (25 credits)
STRIPE_EXPLORER_PRICE_ID=price_...      # A$35 / 2 weeks — Explorer (42 credits)
STRIPE_NOMAD_PRICE_ID=price_...         # A$59 / 2 weeks — Nomad (70 credits)
STRIPE_VAN_LIFER_PRICE_ID=price_...     # A$22 / 2 weeks — Van Lifer (25 credits)

# Resend — get from resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@driftpass.com.au
RESEND_FROM_NAME=DriftPass

# Upstash Redis — for rate limiting (get from upstash.com)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# OneSignal — Phase 3, push notifications
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Mapbox — Phase 4, route map
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to https://driftpass.com.au in prod
NEXT_PUBLIC_PHASE=2                         # controls which features are visible (1-6)

# PIN — dedicated HMAC secret for rotating pass PINs (NEVER use SUPABASE_SERVICE_ROLE_KEY)
# Generate with: openssl rand -hex 32
PIN_HMAC_SECRET=change-me-to-a-random-64-char-hex-string

# Admin — simple secret for admin API routes
ADMIN_SECRET=change-me-to-something-random-and-long

# Analytics — Phase 4
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
